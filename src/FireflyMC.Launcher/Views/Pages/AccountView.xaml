<UserControl x:Class="FireflyMC.Launcher.Views.Pages.AccountView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <TextBlock Text="账号" FontSize="28" FontWeight="SemiBold" Foreground="#111827" />
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,20,0,12">
            <TextBox Width="180" Text="{Binding OfflineUsername, UpdateSourceTrigger=PropertyChanged}" />
            <Button Content="添加离线账号" Command="{Binding AddOfflineCommand}" />
            <Button Content="刷新" Command="{Binding RefreshCommand}" />
            <Button Content="登出" Command="{Binding LogoutCommand}" />
        </StackPanel>
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="260" />
            </Grid.ColumnDefinitions>
            <ListView ItemsSource="{Binding Accounts}"
                      SelectedItem="{Binding SelectedAccount}">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="类型" DisplayMemberBinding="{Binding Type}" Width="120" />
                        <GridViewColumn Header="用户名" DisplayMemberBinding="{Binding Username}" Width="180" />
                        <GridViewColumn Header="UUID" DisplayMemberBinding="{Binding Uuid}" Width="260" />
                        <GridViewColumn Header="最近使用" DisplayMemberBinding="{Binding LastUsedAt}" Width="180" />
                    </GridView>
                </ListView.View>
            </ListView>
            <TextBlock Grid.Column="1"
                       Text="{Binding Status}"
                       TextWrapping="Wrap"
                       Foreground="#4B5563"
                       Margin="16,0,0,0" />
        </Grid>
    </Grid>
</UserControl>
