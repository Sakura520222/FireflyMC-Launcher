<UserControl x:Class="FireflyMC.Launcher.Views.Pages.AboutView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel>
        <TextBlock Text="关于" FontSize="28" FontWeight="SemiBold" Foreground="#111827" />
        <TextBlock Text="FireflyMC Launcher" FontSize="18" Margin="0,24,0,4" />
        <TextBlock Text="{Binding Version, StringFormat=版本 {0}}" Foreground="#4B5563" />
        <StackPanel Orientation="Horizontal" Margin="0,18,0,0">
            <Button Content="检查启动器更新" Command="{Binding CheckUpdateCommand}" />
        </StackPanel>
        <TextBlock Text="{Binding Status}" Foreground="#4B5563" Margin="4,12,4,0" TextWrapping="Wrap" />
    </StackPanel>
</UserControl>
