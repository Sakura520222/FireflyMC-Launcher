<UserControl x:Class="FireflyMC.Launcher.Views.Pages.DownloadView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <TextBlock Text="整合包管理" FontSize="28" FontWeight="SemiBold" Foreground="#111827" />
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,20,0,12">
            <Button Content="检查更新" Command="{Binding CheckCommand}" />
            <Button Content="仅更新" Command="{Binding UpdateCommand}" />
            <Button Content="修复" Command="{Binding RepairCommand}" />
        </StackPanel>
        <StackPanel Grid.Row="2">
            <TextBlock Text="{Binding VersionInfo}" Foreground="#374151" />
            <TextBlock Text="{Binding Status}" Foreground="#4B5563" Margin="0,6,0,6" />
            <ProgressBar Minimum="0" Maximum="100" Height="10" Value="{Binding ProgressValue}" />
        </StackPanel>
        <ListView Grid.Row="3"
                  Margin="0,16,0,0"
                  ItemsSource="{Binding Mods}"
                  VirtualizingPanel.IsVirtualizing="True"
                  VirtualizingPanel.VirtualizationMode="Recycling"
                  ScrollViewer.IsDeferredScrollingEnabled="True">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="名称" DisplayMemberBinding="{Binding Name}" Width="240" />
                    <GridViewColumn Header="文件" DisplayMemberBinding="{Binding FileName}" Width="380" />
                    <GridViewColumn Header="状态" DisplayMemberBinding="{Binding Status}" Width="160" />
                </GridView>
            </ListView.View>
        </ListView>
    </Grid>
</UserControl>
