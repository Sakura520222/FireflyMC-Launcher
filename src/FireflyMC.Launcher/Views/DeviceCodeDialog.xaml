<Window x:Class="FireflyMC.Launcher.Views.DeviceCodeDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Microsoft 登录"
        Height="300"
        Width="480"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <StackPanel Margin="24">
        <TextBlock Text="Microsoft 设备代码登录" FontSize="20" FontWeight="SemiBold" />
        <TextBlock Text="{Binding VerificationUri}" Margin="0,18,0,4" />
        <TextBox Text="{Binding UserCode}" FontSize="24" FontWeight="SemiBold" IsReadOnly="True" />
        <TextBlock Text="{Binding ExpiresText}" Margin="0,12,0,0" Foreground="#4B5563" />
        <TextBlock Text="等待登录" Margin="0,6,0,12" Foreground="#4B5563" />
        <StackPanel Orientation="Horizontal">
            <Button Content="复制代码" Click="CopyCode_Click" />
            <Button Content="打开浏览器" Click="OpenBrowser_Click" />
            <Button Content="继续" IsDefault="True" Click="Continue_Click" />
            <Button Content="取消" IsCancel="True" Click="Cancel_Click" />
        </StackPanel>
    </StackPanel>
</Window>
